[Unit]
Description=Sylvaine Art frontend
After=network.target art-gallery-backend.service

[Service]
User=deploy
Group=deploy
WorkingDirectory=/opt/art-gallery/app/frontend
EnvironmentFile=/opt/art-gallery/env/frontend.env
Environment=NODE_ENV=production
ExecStart=/usr/bin/npm run start -- --hostname 127.0.0.1 --port 3000
Restart=always
RestartSec=5
StandardOutput=append:/var/log/art-gallery/frontend.log
StandardError=append:/var/log/art-gallery/frontend-error.log

[Install]
WantedBy=multi-user.target
