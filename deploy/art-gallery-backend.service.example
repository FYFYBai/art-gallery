[Unit]
Description=Sylvaine Art backend
After=network.target postgresql.service

[Service]
User=deploy
Group=deploy
WorkingDirectory=/opt/art-gallery/app/backend
EnvironmentFile=/opt/art-gallery/env/backend.env
ExecStart=/usr/bin/java -jar /opt/art-gallery/app/backend/target/art-gallery-backend-0.0.1-SNAPSHOT.jar
Restart=always
RestartSec=5
StandardOutput=append:/var/log/art-gallery/backend.log
StandardError=append:/var/log/art-gallery/backend-error.log

[Install]
WantedBy=multi-user.target
